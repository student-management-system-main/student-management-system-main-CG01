# ─── Application ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
FLASK_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Full SQLAlchemy connection URL (used by api and worker)
DATABASE_URL=mysql+pymysql://fee_user:fee_password@db:3306/fee_db

# Individual DB connection params (used by docker-compose for MySQL init)
DB_HOST=db
DB_PORT=3306
DB_NAME=fee_db
DB_USER=fee_user
DB_PASSWORD=fee_password
DB_ROOT_PASSWORD=root_password

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Risk Service ────────────────────────────────────────────────────────────
RISK_SERVICE_URL=http://risk_service:5001
RISK_SERVICE_PORT=5001
MODEL_DIR=/app/models

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Mail (SMTP) ─────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=noreply@example.com

# ─── Twilio (SMS) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000

# ─── Celery Beat Schedule ────────────────────────────────────────────────────
# Cron expression for nightly batch risk scoring (default: midnight daily)
BATCH_SCORE_CRON=0 0 * * *
